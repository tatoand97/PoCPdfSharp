{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PoCPdfSharp": "Information"
    }
  },
  "PdfRendering": {
    "MaxResourceBytes": 2097152,
    "ResourceTimeoutSeconds": 10,
    "AllowHttpsResources": true,
    "AllowDataUriImages": true,
    "RestrictToBaseUriHost": true,
    "MaxLayoutPasses": 4096
  },
  "AllowedHosts": "*"
}
